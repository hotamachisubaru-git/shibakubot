{
  "name": "discord-bot",
  "version": "1.4.1",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "node scripts/clean-dist.mjs && tsc",
    "start": "node dist/index.js",
    "register": "ts-node src/deploy-commands.ts",
    "register:prod": "node dist/deploy-commands.js",
    "migrate": "ts-node scripts/migrate-old-data.ts",
    "release:bundle": "npm run build && node scripts/create-release-bundle.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lavalink-client": "^2.9.9",
    "music-metadata": "^11.12.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "discord.js": {
      "undici": "6.24.1"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
